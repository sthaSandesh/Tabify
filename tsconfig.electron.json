{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-electron",
    "rootDir": "src/electron",
    "noEmit": false,
    "allowJs": false
  },
  "include": ["src/electron/**/*.ts", "src/electron/**/*.cts"]
}
